# Heavy third-party pipeline INPUTS — not redistributed (own licenses):
# WorldClim/Köppen rasters, PlantVillage paths, Bugwood image cache.
data/
extracted_diseases/
*.tif

# Raw / intermediate Bugwood tables — keep only BugWood_Diseases_enriched.csv
BugWood_Diseases.csv
BugWood_Diseases_usable.csv

# Local archive of deprecated/scratch files
_archive/

# Caches, logs, bytecode
__pycache__/
*.pyc
*.pyo
geophyto_qa/logs/*
!geophyto_qa/logs/.gitkeep
geophyto_qa/lookalike/emb_cache/
geophyto_qa/lookalike/emb_cache_flava/
figures/img_cache/

# step-0 label-judge outputs (regenerable)
geophyto_qa/quality/disease_label_full_report.json
geophyto_qa/quality/disease_label_full_progress.txt
geophyto_qa/quality/crop_disease_registry.csv

# Regenerable audit intermediates (rebuilt by the audit/ steps)
geophyto_qa/audit/pathogen_worklist.json
geophyto_qa/audit/pair_claims.json
geophyto_qa/audit/prior_audit.json
geophyto_qa/audit/lane_b_corrections.json

# SLURM run logs (.out/.err live in geophyto_qa/logs/)
*.out
*.err

# Generated Workflow scripts (regenerated by gen_*_workflow.py)
geophyto_qa/lay_workflow*.js
geophyto_qa/lookalike/*workflow*.js

# per-run outputs (regenerable)
geophyto_qa_smoke10.*
geophyto_qa_review10.pdf
